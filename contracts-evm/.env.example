# GSP Contracts — Environment Variables
# Copy to .env and fill in real values. NEVER commit .env to git.

# Deployer wallet private key (no 0x prefix needed)
DEPLOYER_PRIVATE_KEY=your_private_key_here

# Polygon RPC (use Alchemy, Infura, or Chainstack for reliability)
POLYGON_RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# PolygonScan API key for contract verification
POLYGONSCAN_API_KEY=your_polygonscan_api_key

# Owner address (the wallet that receives initial token supply and admin rights)
OWNER_ADDRESS=0xYourOwnerAddressHere

# Pinata IPFS — for uploading agent metadata and avatar assets
# Get from: https://app.pinata.cloud/keys
PINATA_JWT=your_pinata_jwt_here

# OpenSea API key — for reading collection data after deployment
OPENSEA_API_KEY=your_opensea_api_key_here
